{
  "name": "Flux",
  "scopeName": "source.flux",
  "fileTypes": ["flux"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#signal-functions" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#strategy-name" },
    { "include": "#constants" },
    { "include": "#builtin-functions" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "#.*$",
          "name": "comment.line.number-sign.flux"
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "match": "\\b(if|elif|else|for|while|return|in)\\b",
          "name": "keyword.control.flux"
        }
      ]
    },
    "keywords-declaration": {
      "patterns": [
        {
          "match": "\\b(strategy|params|state|on|from|import)\\b",
          "name": "keyword.other.flux"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b(true|false|null)\\b",
          "name": "constant.language.flux"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b[0-9]+\\.[0-9]+\\b",
          "name": "constant.numeric.float.flux"
        },
        {
          "match": "\\b[0-9]+\\b",
          "name": "constant.numeric.integer.flux"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.flux",
          "patterns": [
            {
              "match": "\\\\[nrt\"\\\\]",
              "name": "constant.character.escape.flux"
            }
          ]
        }
      ]
    },
    "signal-functions": {
      "patterns": [
        {
          "match": "\\b(OPEN|CLOSE|CLOSE_QTY)\\b",
          "name": "entity.name.function.signal.flux"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "match": "\\b(sma|ema|stddev|variance|zscore|rsi|atr|corr|covariance|abs|sqrt|exp|log|floor|ceil|round|sign|pow|min|max)\\b",
          "name": "support.function.builtin.flux"
        }
      ]
    },
    "strategy-name": {
      "patterns": [
        {
          "match": "(?<=\\bstrategy\\s)[A-Za-z_][A-Za-z0-9_]*",
          "name": "entity.name.type.strategy.flux"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "\\b(and|or|not)\\b",
          "name": "keyword.operator.logical.flux"
        },
        {
          "match": "==|!=|<=|>=|<|>",
          "name": "keyword.operator.comparison.flux"
        },
        {
          "match": "[+\\-*/%]",
          "name": "keyword.operator.arithmetic.flux"
        },
        {
          "match": "(?<![!=<>])=(?!=)",
          "name": "keyword.operator.assignment.flux"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
          "name": "variable.other.flux"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": "[(){}\\[\\],.:]",
          "name": "punctuation.flux"
        }
      ]
    }
  }
}
