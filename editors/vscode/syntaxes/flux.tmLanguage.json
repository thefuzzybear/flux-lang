{
  "name": "Flux",
  "scopeName": "source.flux",
  "fileTypes": ["flux"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#decorators" },
    { "include": "#signal-functions" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#builtin-types" },
    { "include": "#function-definition" },
    { "include": "#enum-variant-access" },
    { "include": "#struct-type-names" },
    { "include": "#strategy-name" },
    { "include": "#constants" },
    { "include": "#self-keyword" },
    { "include": "#bar-context" },
    { "include": "#builtin-functions" },
    { "include": "#function-call" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "#.*$",
          "name": "comment.line.number-sign.flux"
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "match": "\\b(if|elif|else|for|while|return|in|match)\\b",
          "name": "keyword.control.flux"
        }
      ]
    },
    "keywords-declaration": {
      "patterns": [
        {
          "match": "\\b(strategy|params|state|on|from|import|fn|data|connector|struct|enum|impl|trait)\\b",
          "name": "keyword.other.flux"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b(true|false|null)\\b",
          "name": "constant.language.flux"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b[0-9]+\\.[0-9]+\\b",
          "name": "constant.numeric.float.flux"
        },
        {
          "match": "\\b[0-9]+\\b",
          "name": "constant.numeric.integer.flux"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.flux",
          "patterns": [
            {
              "match": "\\\\[nrt\"\\\\]",
              "name": "constant.character.escape.flux"
            }
          ]
        }
      ]
    },
    "signal-functions": {
      "patterns": [
        {
          "match": "\\b(OPEN|CLOSE|CLOSE_QTY)\\b",
          "name": "entity.name.function.signal.flux"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "match": "\\b(sma|ema|stddev|variance|zscore|rsi|atr|corr|covariance|abs|sqrt|exp|log|floor|ceil|round|sign|pow|min|max|range)\\b",
          "name": "support.function.builtin.flux"
        }
      ]
    },
    "strategy-name": {
      "patterns": [
        {
          "match": "(?<=\\bstrategy\\s)[A-Za-z_][A-Za-z0-9_]*",
          "name": "entity.name.type.strategy.flux"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "match": "@[a-z_]+",
          "name": "meta.decorator.flux"
        }
      ]
    },
    "builtin-types": {
      "patterns": [
        {
          "match": "\\b(f64|int|bool|str|HashMap)\\b",
          "name": "support.type.primitive.flux"
        }
      ]
    },
    "self-keyword": {
      "patterns": [
        {
          "match": "\\bself\\b",
          "name": "variable.language.self.flux"
        }
      ]
    },
    "enum-variant-access": {
      "patterns": [
        {
          "comment": "Enum variant access: EnumName.VariantName or EnumName.VariantName(...)",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\.([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.enum.flux" },
            "2": { "name": "variable.other.enummember.flux" }
          }
        }
      ]
    },
    "struct-type-names": {
      "patterns": [
        {
          "comment": "Capitalized identifiers used as struct/enum/type names (e.g., Quote, Tick, Signal, Regime)",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b",
          "name": "entity.name.type.struct.flux"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "comment": "Function name in a definition: fn calc_spread(...)",
          "match": "(?<=\\bfn\\s)[a-z_][a-zA-Z0-9_]*",
          "name": "entity.name.function.flux"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "comment": "Function call: identifier immediately followed by (",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.flux" }
          }
        }
      ]
    },
    "bar-context": {
      "patterns": [
        {
          "comment": "Built-in bar context variables available in on_bar handlers",
          "match": "\\b(close|open|high|low|volume|symbol|in_position|bar)\\b",
          "name": "variable.language.flux"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "=>",
          "name": "keyword.operator.arrow.match.flux"
        },
        {
          "match": "->",
          "name": "punctuation.arrow.flux"
        },
        {
          "match": "\\b(and|or|not)\\b",
          "name": "keyword.operator.logical.flux"
        },
        {
          "match": "==|!=|<=|>=|<|>",
          "name": "keyword.operator.comparison.flux"
        },
        {
          "match": "[+\\-*/%]",
          "name": "keyword.operator.arithmetic.flux"
        },
        {
          "match": "(?<![!=<>])=(?!=|>)",
          "name": "keyword.operator.assignment.flux"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
          "name": "variable.other.flux"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": "::",
          "name": "punctuation.separator.namespace.flux"
        },
        {
          "match": "[(){}\\[\\],.:;@]",
          "name": "punctuation.flux"
        }
      ]
    }
  }
}
